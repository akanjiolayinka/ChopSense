# =============================================================================
# ChopSense — Environment Variables
# =============================================================================
# HOW TO USE THIS FILE:
#   1. Copy it:   cp .env.example .env
#   2. Fill in your actual values where it says "your_...._here"
#   3. Never share or commit your .env file — it contains secret keys
# =============================================================================


# -----------------------------------------------------------------------
# YOUR API KEYS
# These are the secret keys that connect the app to external services.
# You must fill these in or the app will not work.
# -----------------------------------------------------------------------

# Get this from https://console.anthropic.com — this powers the AI brain
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional. Only used as a backup if the Anthropic API goes down.
OPENAI_API_KEY=sk-your-openai-key-here


# -----------------------------------------------------------------------
# AI MODEL SETTINGS
# These control which AI models the app uses.
# You do not need to change these unless you know what you are doing.
# -----------------------------------------------------------------------

# The Claude model that reasons and generates recommendations
LLM_MODEL=claude-sonnet-4-20250514

# How creative the AI responses are. 0 = very precise, 1 = very creative.
# 0.3 is the sweet spot for recommendation responses.
LLM_TEMPERATURE=0.3

# Maximum words the AI can write in one response
LLM_MAX_TOKENS=1000

# The model that converts restaurants and queries into searchable vectors
EMBEDDING_MODEL=all-mpnet-base-v2

# The model that precisely re-ranks the top 50 candidates to top 10
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2


# -----------------------------------------------------------------------
# DATABASE — POSTGRESQL
# This is where all the restaurant data and embeddings are stored.
# If you are running with Docker (recommended), just change the password.
# -----------------------------------------------------------------------

# Full connection string — change "your_password_here" to match below
DATABASE_URL=postgresql://admin:your_password_here@db:5432/chopsense

# These must all match each other
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=chopsense

# Use "db" when running with Docker, "localhost" when running locally
POSTGRES_HOST=db
POSTGRES_PORT=5432


# -----------------------------------------------------------------------
# SESSION STORAGE — REDIS
# This remembers the conversation between messages in a chat session.
# If you are running with Docker, you do not need to change anything here.
# -----------------------------------------------------------------------

# Use "redis" when running with Docker, "localhost" when running locally
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# How long (in seconds) before an inactive chat session is cleared.
# 3600 = 1 hour. Increase if users take long breaks between messages.
SESSION_TTL_SECONDS=3600


# -----------------------------------------------------------------------
# RECOMMENDATION SETTINGS
# These control how the two-stage retrieval pipeline behaves.
# -----------------------------------------------------------------------

# Stage 1: How many restaurants to pull from the database as rough candidates
RETRIEVAL_TOP_K=50

# Stage 2: How many to keep after precise re-ranking
RERANK_TOP_N=10

# Users with fewer reviews than this get the cold-start onboarding flow
MIN_USER_REVIEWS=10

# How many chat turns to remember per session
MAX_CONTEXT_TURNS=20

# Set to false only when running ablation studies — leave as true normally
ENABLE_CULTURAL_LAYER=true

# Includes the AI's reasoning in the API response — useful for the paper
ENABLE_REASONING_TRACE=true


# -----------------------------------------------------------------------
# APP SERVER
# -----------------------------------------------------------------------

# The port the API runs on
API_PORT=8000

# The port the React frontend runs on
FRONTEND_PORT=3000

# This tells the frontend where to find the API
VITE_API_BASE_URL=http://localhost:8000

# Which URLs are allowed to talk to the API (your frontend URL goes here)
CORS_ORIGINS=http://localhost:3000

# How much to log. Use DEBUG when hunting a bug, INFO normally.
LOG_LEVEL=INFO

# Use "development" locally, "production" when deploying
ENVIRONMENT=development


# -----------------------------------------------------------------------
# MAP
# Leaflet.js is used for the live restaurant map in the frontend.
# OpenStreetMap is free and needs no key — leave this as is.
# If you want to use Google Maps instead, add your key below.
# -----------------------------------------------------------------------

LEAFLET_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
GOOGLE_MAPS_API_KEY=


# -----------------------------------------------------------------------
# DATA FOLDERS
# Where the pipeline saves processed files.
# You do not need to change these.
# -----------------------------------------------------------------------

DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
EVAL_OUTPUT_DIR=./results
