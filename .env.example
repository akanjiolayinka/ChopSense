# ChopSense environment configuration.
# Copy this file to .env and fill in real values before running the system.

# --- Application -------------------------------------------------------------
APP_NAME=ChopSense
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

# --- API ---------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- LLM ---------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-key-here
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1024

# --- Embeddings and re-ranking ----------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DIM=768
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Retrieval pipeline ------------------------------------------------------
RETRIEVAL_TOP_K=50
RERANK_TOP_N=10

# --- Datastores --------------------------------------------------------------
DATABASE_URL=postgresql://chopsense:chopsense@db:5432/chopsense
REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=3600

# --- Feature flags -----------------------------------------------------------
ENABLE_CULTURAL_LAYER=true
ENABLE_REASONING_TRACE=true
